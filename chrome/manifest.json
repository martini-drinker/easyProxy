{
	"manifest_version": 3,
	"name": "EasyProxy",
	"version": "1.3",
	"description": "Simple proxy switcher.",
	"icons": {
		"16": "img/16.png",
		"32": "img/32-regular.png",
		"48": "img/48.png",
		"128": "img/128.png"
	},
	"background": {
		"service_worker": "service-worker.js"
	},
	"action": {
		"default_icon": "img/32-off.png",
		"default_title": "EasyProxy",
		"default_popup": "popup/index.html"
	},
	"permissions": [
		"storage",
		"tabs",
		"proxy",
		"webRequest",
		"webRequestAuthProvider"
	],
	"host_permissions": [
		"<all_urls>"
	],
	"incognito": "split"
}
